rules_version = '2';

// 脚本マーケット Firestore セキュリティルール (Pass1 暫定版)
//
// 基本方針 (spec-details.md §5):
// - 公開リソース (scripts published / users プロフィール / config) は誰でも read
// - 個人リソース (favorites / chats / consultations / invoices) は当事者のみ
// - 書き込みは Server Actions 経由を基本とし、Admin SDK で操作する
// - クライアント onSnapshot を許可するリソース (users / chats(messages) / scripts) のみ client read を開放
//
// このファイルは P1-4 で初版を deploy し、P1-18 で最終調整する。

service cloud.firestore {
  match /databases/{database}/documents {

    // ----- ヘルパー関数 -----
    function isSignedIn() {
      return request.auth != null;
    }
    function isMe(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }

    // ----- users -----
    match /users/{uid} {
      allow read: if true; // プロフィールは公開
      allow create: if isMe(uid);
      allow update: if isMe(uid);
      allow delete: if isMe(uid);

      match /favorites/{docId} {
        allow read, write: if isMe(uid);
      }
      match /history/{docId} {
        allow read, write: if isMe(uid);
      }
      match /savedSearches/{docId} {
        allow read, write: if isMe(uid);
      }
    }

    // ----- userIds (補助索引、書き込みは Server Actions 経由のみ) -----
    match /userIds/{userId} {
      allow read: if true;
      // クライアントから直接書き込み禁止 (Admin SDK 経由のみ)
      allow write: if false;
    }

    // ----- scripts -----
    match /scripts/{scriptId} {
      allow read: if resource.data.status == 'published'
        || (isSignedIn() && request.auth.uid == resource.data.authorUid);
      allow create: if isSignedIn();
      allow update, delete: if isSignedIn() && request.auth.uid == resource.data.authorUid;

      match /versions/{versionId} {
        allow read: if true;
        allow write: if isSignedIn()
          && request.auth.uid == get(/databases/$(database)/documents/scripts/$(scriptId)).data.authorUid;
      }
      match /reviews/{reviewerUid} {
        allow read: if true;
        allow write: if isMe(reviewerUid);
      }
    }

    // ----- chats -----
    // chats / messages の作成は Server Actions (Admin SDK) 経由のみに統一する。
    // クライアントから直接 create する経路は無いため、create は禁止する。
    // read は参加者のみ（onSnapshot 用にクライアント許可）。
    match /chats/{chatId} {
      allow read: if isSignedIn() && request.auth.uid in resource.data.participants;
      allow create, update, delete: if false;

      match /messages/{messageId} {
        allow read: if isSignedIn()
          && request.auth.uid in get(/databases/$(database)/documents/chats/$(chatId)).data.participants;
        // Pass1 では client から直接書き込みしない（Server Action 経由）。
        // 将来クライアント送信が必要になった際に解放する想定。
        allow create, update, delete: if false;
      }
    }

    // ----- consultations -----
    match /consultations/{consultationId} {
      allow read: if isSignedIn()
        && (request.auth.uid == resource.data.requesterUid
          || request.auth.uid == resource.data.authorUid);
      allow create: if isSignedIn();
      allow update: if isSignedIn()
        && (request.auth.uid == resource.data.requesterUid
          || request.auth.uid == resource.data.authorUid);
      allow delete: if false;
    }

    // ----- invoices -----
    match /invoices/{invoiceId} {
      allow read: if isSignedIn()
        && (request.auth.uid == resource.data.creatorUid
          || request.auth.uid == resource.data.payerUid);
      allow create: if isSignedIn();
      // ステータス更新は Server Actions / Webhook 経由 (Admin SDK)
      allow update, delete: if false;
    }

    // ----- purchases -----
    match /purchases/{purchaseId} {
      allow read: if isSignedIn() && request.auth.uid == resource.data.buyerUid;
      // 作成は Server Actions / Webhook 経由のみ
      allow create, update, delete: if false;
    }

    // ----- reports -----
    match /reports/{reportId} {
      allow create: if isSignedIn();
      // 読み取りは管理者のみ (Admin SDK)
      allow read, update, delete: if false;
    }

    // ----- config -----
    match /config/{docId} {
      allow read: if true;
      // 更新は管理者 Server Actions 経由
      allow write: if false;
    }
  }
}
